{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron",
      "destination": "/api/main"
    },
    {
      "source": "/(.*)",
      "destination": "/api/main"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60
    }
  }
}
